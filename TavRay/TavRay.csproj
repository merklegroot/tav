<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Tav</RootNamespace>
    <AssemblyName>TavRay</AssemblyName>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.5" />
    <PackageReference Include="Raylib-cs" Version="5.0.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\TavLib\TavLib.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Fonts\AnonymousPro.ttf" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Fonts\AnonymousPro-OFL.txt" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Fonts\ATTRIBUTION.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
